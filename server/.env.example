# ============================================
# FitTrack Pro — Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace_with_your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_your_supabase_service_role_key

# CORS
CLIENT_URL=http://localhost:4200,https://your-production-frontend.vercel.app

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp
